<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".VollaHubApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_vollahub_pictogram_dark_02"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_vollahub_pictogram_dark_02_round"
        android:theme="@style/Theme.VollaHub"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

        <activity
            android:name="com.volla.hub.StartActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.volla.hub.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name="com.volla.hub.ContentActivity"
            android:exported="false"
            android:parentActivityName="com.volla.hub.MainActivity" />

        <activity
            android:name="com.volla.hub.DeviceReportActivity"
            android:exported="false"
            android:label="Geräte-Report"
            android:parentActivityName="com.volla.hub.MainActivity" />

        <activity
            android:name="com.volla.hub.ReportHistoryActivity"
            android:exported="false"
            android:label="Bericht-Historie"
            android:parentActivityName="com.volla.hub.DeviceReportActivity" />

        <activity
            android:name="com.volla.hub.ChatBotActivity"
            android:exported="false"
            android:label="HelpBot"
            android:parentActivityName="com.volla.hub.MainActivity"
            android:windowSoftInputMode="adjustResize" />
    </application>
</manifest>